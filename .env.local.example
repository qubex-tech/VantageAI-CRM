# Patient portal — Retell web chat (https://docs.retellai.com/deploy/chat-widget)
# Public key: set here OR in Settings → Retell → Patient portal chat public key (Settings wins).
# NEXT_PUBLIC_RETELL_PUBLIC_KEY=key_xxxxxxxx
# Optional agent when Settings → Patient portal chat agent ID is empty
# NEXT_PUBLIC_RETELL_AGENT_ID=agent_xxxxxxxx
# If your Retell public key uses reCAPTCHA v3, set the Google site key (empty chat panel without it)
# NEXT_PUBLIC_RETELL_RECAPTCHA_SITE_KEY=
# Optional: pin agent version string if latest breaks the embed (Retell dashboard)
# NEXT_PUBLIC_RETELL_CHAT_AGENT_VERSION=0

# Supabase Auth Configuration
NEXT_PUBLIC_SUPABASE_URL=https://yxmtekolhhyeypicyfzq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Get your anon key from:
# Supabase Dashboard → Settings → API → Project API keys → anon public

# MCP Verification Server (used by /api/mcp/* and /mcp/* rewrites)
# Comma-separated keys; clients send one via X-API-Key header
MCP_API_KEYS=your-mcp-api-key-here
# Optional: allowed origins for CORS (comma-separated). If unset, allows * for browser MCP clients.
# MCP_CORS_ORIGINS=https://app.retellai.com,https://retellai.com
# Optional: allow agents to receive unmasked member_id/group_number when X-Allow-Unmasked: true
# ALLOW_AGENT_UNMASKED=false

# Curogram AI Escalation to Text (legacy global fallback)
# Prefer configuring Curogram settings per practice in Settings > RetellAI Integration.
# CUROGRAM_AI_ESCALATION_URL=https://voip.curogram.com/ai-escalation-to-text/your-practice-guid
# Optional auth header support (if Curogram account requires it)
# CUROGRAM_AI_ESCALATION_AUTH_HEADER=x-api-key
# CUROGRAM_AI_ESCALATION_AUTH_VALUE=your-curogram-api-key
# Optional intent fallback if call reason is unavailable
# CUROGRAM_AI_ESCALATION_DEFAULT_INTENT=AI call escalation
# Optional timeout in milliseconds (Curogram recommends short timeouts)
# CUROGRAM_AI_ESCALATION_TIMEOUT_MS=3000
