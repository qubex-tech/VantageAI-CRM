# Required: Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Recommended: Exa.ai API key for play-maker deep research (https://exa.ai)
# Without this, play-maker research still works but only uses Gemini + Google Search,
# losing the deeper article/interview content that Exa surfaces.
EXA_API_KEY=

# Optional: override the default models
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_STRUCTURE_MODEL=gemini-2.5-flash

# Server port (defaults to 8787)
# PORT=8787
