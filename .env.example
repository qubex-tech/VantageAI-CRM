# Database
DATABASE_URL="postgresql://user:password@localhost:5432/medical_crm?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Cal.com Integration (optional - can be configured per-practice in UI)
CALCOM_API_KEY="your-calcom-api-key"

# RetellAI Webhook (optional)
RETELLAI_WEBHOOK_SECRET="your-retellai-webhook-secret"
# Default practice ID when not in URL/header/payload (for single-practice or RetellAI test webhook)
RETELLAI_DEFAULT_PRACTICE_ID="demo-practice-1"
# Set to 1 to skip signature verification for local testing (simulate scripts)
RETELLAI_SKIP_SIGNATURE_VERIFICATION=0

# Node Environment
NODE_ENV="development"

# eClinicalWorks — patient Documentation tab (Vantage Backend Services app)
# FHIR base for your tenant (example: staging FFBJCD).
# VANTAGE_ECW_FHIR_BASE_URL="https://staging-fhir.ecwcloud.com/fhir/r4/FFBJCD"
# OAuth client for client_credentials (do not commit real secrets).
# VANTAGE_ECW_CLIENT_ID=""
# VANTAGE_ECW_CLIENT_SECRET=""
# Optional: override token URL if SMART discovery is unavailable.
# VANTAGE_ECW_TOKEN_URL=""
# Optional: override scopes (defaults include system/DocumentReference.read system/Patient.read).
# VANTAGE_ECW_SCOPE=""
# Optional dev shortcut: bypass token exchange (expires must be refreshed manually).
# VANTAGE_ECW_STATIC_ACCESS_TOKEN=""
