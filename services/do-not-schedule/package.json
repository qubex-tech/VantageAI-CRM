{
  "name": "do-not-schedule-lookup",
  "version": "1.0.0",
  "private": true,
  "description": "Retell custom-function HTTP endpoint that checks a caller against the Do Not Schedule list.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "retell-sdk": "^4.42.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
