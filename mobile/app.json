{
  "expo": {
    "name": "VantageAI CRM",
    "slug": "vantage-crm",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "vantagecrm",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vantageai.crm",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture photos for patient documents",
        "NSPhotoLibraryUsageDescription": "Used to attach images to patient records",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },
    "android": {
      "package": "com.vantageai.crm",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
