{
  "expo": {
    "name": "VantageAI CRM",
    "slug": "vantageai-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "vantagecrm",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B6FEA"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7fc52a22-fa78-4cd4-83c7-5a342ab8377e",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vantageai.crm",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "NSMicrophoneUsageDescription": "Aria needs microphone access to record visit audio for draft clinical notes."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vantageai.crm",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B6FEA"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#3B82F6",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Aria needs microphone access to record visit audio for draft clinical notes."
        }
      ],
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "7fc52a22-fa78-4cd4-83c7-5a342ab8377e"
      }
    },
    "owner": "velocity86"
  }
}
