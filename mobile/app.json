{
  "expo": {
    "name": "VantageAI CRM",
    "slug": "vantage-crm",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "vantagecrm",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vantageai.crm",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture photos for patient documents",
        "NSPhotoLibraryUsageDescription": "Used to attach images to patient records",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },
    "android": {
      "package": "com.vantageai.crm",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#3B82F6",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7fc52a22-fa78-4cd4-83c7-5a342ab8377e",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "7fc52a22-fa78-4cd4-83c7-5a342ab8377e"
      }
    },
    "owner": "saqibnasir"
  }
}
