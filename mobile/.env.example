# VantageAI CRM Mobile App — Environment Variables
# Copy this file to .env and fill in the values.
# All EXPO_PUBLIC_* vars are bundled into the app binary at build/publish time.

# Base URL of the VantageAI CRM backend.
# For local development: http://localhost:3000
# For production: your Vercel deployment URL (e.g. https://your-app.vercel.app)
EXPO_PUBLIC_API_URL=https://your-app.vercel.app
