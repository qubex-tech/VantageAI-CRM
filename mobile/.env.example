# VantageAI CRM Mobile App — Environment Variables
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# All EXPO_PUBLIC_* vars are embedded in the app binary at build time.

# Backend API URL (no trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── Local development ─────────────────────────────────────────────────────────
# Point at your local Next.js server, or run ./update-url.sh to sync production URL.

# ── EAS production / preview builds (required) ────────────────────────────────
# Set in Expo dashboard: Project → Environment variables
#   EXPO_PUBLIC_API_URL = https://your-production-app.vercel.app
#
# Or via CLI:
#   eas env:create --name EXPO_PUBLIC_API_URL --value https://your-app.vercel.app --environment production
#   eas env:create --name EXPO_PUBLIC_API_URL --value https://your-app.vercel.app --environment preview
#
# Then build:
#   eas build --platform ios --profile production
#   eas build --platform android --profile production
